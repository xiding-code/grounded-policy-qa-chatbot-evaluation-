# Copy this file to .env and fill in your real keys.
# Never commit .env. The .gitignore in this repo excludes it.

# --- Provider selection ---
# Options: anthropic | openai
LLM_PROVIDER=anthropic

# --- Model selection (optional, sensible defaults if unset) ---
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# --- API keys ---
ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-ANTHROPIC-KEY-HERE
OPENAI_API_KEY=sk-PASTE-YOUR-OPENAI-KEY-HERE

# --- Generation params (optional) ---
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=400
